METRICS = ["root_used", "kaiming", "ostree_upper", "kare_upper"]


def project_root() -> Path:
    return Path(__file__).resolve().parents[1]


def helper_path() -> Path:
    return project_root() / "bin" / "kylin-space-guard"


def run_capture(command):
    return subprocess.run(
        [str(x) for x in command],
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        errors="replace",
    )


def du_bytes(paths):
    total = 0
    for pattern in paths:
        proc = subprocess.run(
            ["bash", "-lc", f"du -sx {pattern} 2>/dev/null | awk '{{s += $1}} END {{print s + 0}}'"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        try:
            total += int(proc.stdout.strip() or "0") * 1024
        except ValueError:
            pass
    return total


def root_used_bytes():
    return shutil.disk_usage("/").used


def current_metrics():
    return {
        "root_used": root_used_bytes(),
        "kaiming": du_bytes(["/var/opt/kaiming"]),
        "ostree_upper": du_bytes(
            [
                "/sysroot/ostree/pkgs/*/*-ovl/*-upper",
                "/sysroot/ostree/pkgs/*/*-ovl/*-tmpupper",
            ]
        ),
        "kare_upper": du_bytes(
            [
                "/opt/kare-applications/*/upper",
                "/opt/kare-applications/*/work",
            ]
        ),
    }


def fmt_size(value):
    if value is None:
        return "-"
    units = ["B", "KiB", "MiB", "GiB", "TiB"]
    size = float(max(value, 0))
    for unit in units:
        if size < 1024 or unit == units[-1]:
            if unit == "B":
                return f"{int(size)} {unit}"
            return f"{size:.1f} {unit}"
        size /= 1024
    return f"{size:.1f} TiB"


class SpaceGuardWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title=TEXT[DEFAULT_LANG]["title"])
        self.set_default_size(920, 680)
        self.set_border_width(12)
        self.user = os.environ.get("SUDO_USER") or getpass.getuser()
        self.helper = helper_path()
        self.baseline = None
        self.current = None
        self.lang = DEFAULT_LANG

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        self.add(root)

        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        root.pack_start(header, False, False, 0)

        self.title_label = Gtk.Label()
        self.title_label.set_xalign(0)
        header.pack_start(self.title_label, True, True, 0)

        self.lang_label = Gtk.Label()
        header.pack_start(self.lang_label, False, False, 0)
        self.lang_combo = Gtk.ComboBoxText()
        self.lang_combo.append("zh", "中文")
        self.lang_combo.append("en", "English")
        self.lang_combo.set_active_id(self.lang)
        self.lang_combo.connect("changed", self.on_language_changed)
        header.pack_start(self.lang_combo, False, False, 0)

        self.user_label = Gtk.Label()
        header.pack_start(self.user_label, False, False, 0)
        self.user_value = Gtk.Label(label=self.user)
        self.user_value.set_selectable(True)
        self.user_value.set_xalign(0)
        header.pack_start(self.user_value, False, False, 0)

        self.summary = Gtk.Label()
        self.summary.set_xalign(0)
        self.summary.set_line_wrap(True)
        root.pack_start(self.summary, False, False, 0)

        self.metric_grid = Gtk.Grid()
        self.metric_grid.set_column_spacing(18)
        self.metric_grid.set_row_spacing(8)
        root.pack_start(self.metric_grid, False, False, 0)
        self.metric_labels = {}
        self.metric_header_labels = []
        for col in range(4):
            label = Gtk.Label()
            label.set_xalign(0)
            self.metric_header_labels.append(label)
            self.metric_grid.attach(label, col, 0, 1, 1)

        self.metric_name_labels = {}
        for row, key in enumerate(METRICS, start=1):
            name_label = Gtk.Label()
            name_label.set_xalign(0)
            self.metric_name_labels[key] = name_label
            self.metric_grid.attach(name_label, 0, row, 1, 1)
            self.metric_labels[key] = {}
            for col, field in enumerate(("before", "released", "current"), start=1):
                value = Gtk.Label(label="-")
                value.set_xalign(0)
                value.set_width_chars(14)
                self.metric_labels[key][field] = value
                self.metric_grid.attach(value, col, row, 1, 1)

        action_bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        root.pack_start(action_bar, False, False, 0)

        self.scan_button = Gtk.Button()
        self.scan_button.connect("clicked", lambda _b: self.scan())
        action_bar.pack_start(self.scan_button, False, False, 0)

        self.disable_autostart_button = Gtk.Button()
        self.disable_autostart_button.connect(
            "clicked", lambda _b: self.apply_action("--disable-kaiming-autostart", self.t("action_disable"))
        )
        action_bar.pack_start(self.disable_autostart_button, False, False, 0)

        self.quarantine_button = Gtk.Button()
        self.quarantine_button.connect(
            "clicked", lambda _b: self.apply_action("--clean-old-app-containers", self.t("action_clean_old_containers"))
        )
        action_bar.pack_start(self.quarantine_button, False, False, 0)

        self.monitor_button = Gtk.Button()
        self.monitor_button.connect("clicked", lambda _b: self.apply_action("--install-monitor", self.t("action_monitor")))
        action_bar.pack_start(self.monitor_button, False, False, 0)

        self.status = Gtk.Label()
        self.status.set_xalign(0)
        root.pack_start(self.status, False, False, 0)

        self.expander = Gtk.Expander()
        self.expander.set_expanded(False)
        root.pack_start(self.expander, True, True, 0)

        scrolled = Gtk.ScrolledWindow()
        scrolled.set_hexpand(True)
        scrolled.set_vexpand(True)
        self.expander.add(scrolled)

        self.output = Gtk.TextView()
        self.output.set_editable(False)
        self.output.set_monospace(True)
        self.output.set_wrap_mode(Gtk.WrapMode.NONE)
        scrolled.add(self.output)

        self.apply_language()
        self.scan()

    def t(self, key):
        return TEXT[self.lang][key]

    def on_language_changed(self, combo):
        active = combo.get_active_id()
        if active in TEXT and active != self.lang:
            self.lang = active
            self.apply_language()
            if self.baseline and self.current:
                self.update_metrics(self.baseline, self.current)

    def apply_language(self):
        self.set_title(self.t("title"))
        self.title_label.set_markup(f"<b>{self.t('title')}</b>")
        self.lang_label.set_text(self.t("lang_label"))
        self.user_label.set_text(self.t("user"))
        for label, key in zip(self.metric_header_labels, ("area", "before", "released", "current")):
            label.set_markup(f"<b>{self.t(key)}</b>")
        for key in METRICS:
            self.metric_name_labels[key].set_text(self.t(key))
        self.scan_button.set_label(self.t("scan"))
        self.disable_autostart_button.set_label(self.t("disable_autostart"))
        self.quarantine_button.set_label(self.t("clean_old_containers"))
        self.monitor_button.set_label(self.t("monitor"))
        self.expander.set_label(self.t("details"))
        if not self.baseline:
            self.summary.set_text(self.t("intro"))
            self.status.set_text(self.t("ready"))

    def append_output(self, text):
        buf = self.output.get_buffer()
        end = buf.get_end_iter()
        buf.insert(end, text)
        mark = buf.create_mark(None, buf.get_end_iter(), False)
        self.output.scroll_to_mark(mark, 0.0, True, 0.0, 1.0)

    def set_output(self, text):
        self.output.get_buffer().set_text(text)

    def update_metrics(self, baseline, current):
        self.baseline = baseline
        self.current = current
        total_released = 0
        for key in METRICS:
            before = baseline.get(key)
            now = current.get(key)
            released = max(before - now, 0)
            total_released += released if key != "root_used" else 0
            self.metric_labels[key]["before"].set_text(fmt_size(before))
            self.metric_labels[key]["released"].set_text(fmt_size(released))
            self.metric_labels[key]["current"].set_text(fmt_size(now))
        self.summary.set_text(
            self.t("summary").format(
                kaiming=fmt_size(baseline.get("kaiming")),
                ostree=fmt_size(baseline.get("ostree_upper")),
                kare=fmt_size(baseline.get("kare_upper")),
                released=fmt_size(total_released),
            )
        )

    def set_busy(self, busy, message):
        self.status.set_text(message)
        for button in (
            self.scan_button,
            self.disable_autostart_button,
            self.quarantine_button,
            self.monitor_button,
        ):
            button.set_sensitive(not busy)

    def base_args(self):
        return [self.helper, "--user", self.user]

    def scan(self):
        self.set_output("")
        self.set_busy(True, self.t("scanning"))

        def worker():
            before = current_metrics()
            proc = run_capture(self.base_args() + ["--dry-run"])
            after = current_metrics()
            GLib.idle_add(self.update_metrics, before, after)
            GLib.idle_add(self.append_output, proc.stdout)
            GLib.idle_add(self.set_busy, False, self.t("scan_done").format(code=proc.returncode))

        threading.Thread(target=worker, daemon=True).start()

    def run_apply(self, action_args, action_label):
        self.set_output("")
        self.set_busy(True, self.t("running").format(action=action_label))

        def worker():
            before = current_metrics()
            command = ["pkexec"] + self.base_args() + ["--apply"] + action_args
            proc = run_capture(command)
            after = current_metrics()
            GLib.idle_add(self.update_metrics, before, after)
            GLib.idle_add(self.append_output, proc.stdout)
            GLib.idle_add(
                self.set_busy,
                False,
                self.t("action_done").format(action=action_label, code=proc.returncode),
            )

        threading.Thread(target=worker, daemon=True).start()

    def apply_action(self, action, action_label):
        if not self.confirm_apply(action_label):
            return
        self.run_apply([action], action_label)

    def confirm_apply(self, action):
        dialog = Gtk.MessageDialog(
            transient_for=self,
            flags=0,
            message_type=Gtk.MessageType.WARNING,
            buttons=Gtk.ButtonsType.OK_CANCEL,
            text=self.t("confirm_title"),
        )
        dialog.format_secondary_text(self.t("confirm_body").format(action=action))
        response = dialog.run()
        dialog.destroy()
        return response == Gtk.ResponseType.OK

    def message(self, title, body):
        dialog = Gtk.MessageDialog(
            transient_for=self,
            flags=0,
            message_type=Gtk.MessageType.INFO,
            buttons=Gtk.ButtonsType.OK,
            text=title,
        )
        dialog.format_secondary_text(body)
        dialog.run()
        dialog.destroy()


def main():
    helper = helper_path()
    if not helper.exists():
        print(TEXT[DEFAULT_LANG]["helper_missing"].format(path=helper), file=sys.stderr)
        return 1
    win = SpaceGuardWindow()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
